generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Producto {
  id            Int      @id @default(autoincrement())
  nombre        String
  slug          String   @unique
  descripcion   String
  precio        Decimal  @db.Decimal(10, 2)
  imagen        String
  imagenes      String[]
  disponible    Boolean  @default(true)
  categoria     String?
  tallas        String[]
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
}

model Admin {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
}

model ConfigSitio {
  id                Int     @id
  logoUrl           String?
  nosotrosHistoria1 String?
  nosotrosHistoria2 String?
  nosotrosFilosofia String?
  contactoEmail     String?
}
